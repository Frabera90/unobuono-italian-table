# Supabase (public — safe to expose in client-side code)
VITE_SUPABASE_URL=https://<project-ref>.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=<anon-key>
VITE_SUPABASE_PROJECT_ID=<project-ref>

# Supabase (also needed server-side by some adapters)
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_PUBLISHABLE_KEY=<anon-key>

# Supabase service role (NEVER expose to the browser)
# Required by server routes (cron, email send)
# Set via environment secrets in your hosting platform
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>
